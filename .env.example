# ============================================================================
# Eresus Sentinel — Environment Variables
# ============================================================================
# Copy this file to .env and fill in required values:
#   cp .env.example .env
# ============================================================================

# ── Required ─────────────────────────────────────────────────────────────────
# PostgreSQL password (REQUIRED for docker-compose)
POSTGRES_PASSWORD=changeme_postgres_password

# Sentinel admin password (REQUIRED for docker-compose)
SENTINEL_PASSWORD=changeme_sentinel_password

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=sentinel
POSTGRES_USER=sentinel
POSTGRES_PORT=5433

# ── Sentinel API ─────────────────────────────────────────────────────────────
SENTINEL_ENV=production
SENTINEL_LOG_LEVEL=INFO
SENTINEL_PORT=8080
SENTINEL_USER=admin

# Authentication (recommended for production)
# Options: bearer, api-key, or leave empty to disable
SENTINEL_AUTH_TYPE=bearer
SENTINEL_AUTH_TOKEN=changeme_api_token

# CORS origins (comma-separated)
SENTINEL_CORS_ORIGINS=http://localhost:8080

# Rate limiting
SENTINEL_RATE_LIMIT=100/minute

# Vault encryption (0=disabled, 1=enabled)
SENTINEL_VAULT=0

# ── AI Backend (optional) ───────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── HuggingFace (optional) ──────────────────────────────────────────────────
HF_TOKEN=

# ── Prometheus ───────────────────────────────────────────────────────────────
PROMETHEUS_PORT=19090
