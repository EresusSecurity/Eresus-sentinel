# ============================================================================
# Eresus Sentinel — CUDA-enabled Docker Image
# For GPU-accelerated ML model scanning and AI-assisted analysis
# ============================================================================
# Usage:
#   docker build -f Dockerfile.cuda -t eresus/sentinel:cuda .
#   docker run --gpus all -p 8080:8080 eresus/sentinel:cuda
# ============================================================================

FROM nvidia/cuda:12.4.1-runtime-ubuntu22.04

LABEL org.opencontainers.image.source="https://github.com/eresus-security/sentinel"
LABEL org.opencontainers.image.title="Eresus Sentinel (CUDA)"
LABEL org.opencontainers.image.description="GPU-accelerated AI/LLM Security Platform"

# System deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.12 \
    python3.12-venv \
    python3-pip \
    tini \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Non-root user
RUN groupadd -r sentinel && useradd -r -g sentinel -d /app -s /sbin/nologin sentinel

WORKDIR /app

COPY --chown=sentinel:sentinel pyproject.toml ./
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir ".[all,otel]"

COPY --chown=sentinel:sentinel python/ ./python/
COPY --chown=sentinel:sentinel rules/ ./rules/
COPY --chown=sentinel:sentinel config/ ./config/
RUN pip install --no-cache-dir -e "."

RUN mkdir -p /app/logs /app/data && chown -R sentinel:sentinel /app

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONPATH=/app/python \
    SENTINEL_ENV=production \
    PORT=8080

USER sentinel
EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=3 \
    CMD python3 -c "import urllib.request; urllib.request.urlopen('http://localhost:8080/health')" || exit 1

ENTRYPOINT ["tini", "--"]
CMD ["python3", "-m", "uvicorn", "sentinel.server:create_app", \
     "--factory", "--host", "0.0.0.0", "--port", "8080", \
     "--workers", "2", "--log-level", "info"]
