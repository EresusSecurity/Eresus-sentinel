schema: sentinel.plugin.v1
id: sentinel.local.rulepack
name: Local Rule Pack
version: 0.1.0
kind: rulepack
description: Declarative rule pack manifest for local deterministic checks.
permissions:
  - scan:file-read
  - scan:prompt
  - network:none
formats:
  - .sntl
  - .sentinel
hooks:
  - id: prompt-rules
    type: assertion-pack
    path: examples/assertion-pack.sntl
trust:
  provenance: local
  signed: false
