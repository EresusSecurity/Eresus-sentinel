@dataclass
class Result:
    name: str
    category: str
    method: str
    path: str
    expected: str
    status_code: int
    duration_ms: float
    passed: bool
    skipped: bool = False
    json_valid: bool = False
    finding_count: int | None = None
    action: str = ""
    issue_flags: list[str] = field(default_factory=list)
    evidence: str = ""
    body_prefix: str = ""


@dataclass
class RequestSpec:
    name: str
    category: str
    method: str
    path: str
    expected_status: set[int]
    body: Any = None
    headers: dict[str, str] = field(default_factory=dict)
    auth: bool = False
    expect_json: bool = True
    expect_csp: bool = False
    expect_no_server_header: bool = False
    min_findings: int | None = None
    max_findings: int | None = None
    expected_action: set[str] | None = None
    skip_reason: str = ""
    upload_file: Path | None = None
    upload_field: str = "file"


def now_ms() -> float:
    return time.perf_counter() * 1000


def join_url(base_url: str, path: str) -> str:
    return base_url.rstrip("/") + "/" + path.lstrip("/")


def safe_preview(value: str, limit: int = 1000) -> str:
    value = value.replace("\r", "\\r").replace("\n", "\\n")
    return value[:limit]


def load_json(text: str) -> tuple[bool, Any]:
    try:
        return True, json.loads(text)
    except Exception:
        return False, None


def write_json(path: Path, payload: Any) -> None:
    path.write_text(json.dumps(payload, indent=2, ensure_ascii=False), encoding="utf-8")


def write_text(path: Path, value: str) -> None:
    path.write_text(value, encoding="utf-8")


def ensure_fixtures(root: Path) -> dict[str, Path]:
    fixtures = root / "fixtures"
    fixtures.mkdir(parents=True, exist_ok=True)

    files: dict[str, tuple[str, str]] = {
        "clean_py": ("clean.py", 'print("hello")\n'),
        "suspicious_py": ("suspicious.py", 'import os\nos.system("id")\n'),
        "secrets_py": ("secrets.py", 'API_KEY="sk-test-1234567890abcdefghijklmnopqrstuvwxyz"\n'),
        "requirements": ("requirements.txt", "requests==2.31.0\n"),
        "package": ("package.json", '{"name":"sentinel-api-qa","version":"1.0.0"}\n'),
        "dockerfile": ("Dockerfile", "FROM python:3.12\n"),
        "artifact_pkl": ("model.pkl", "cos\nsystem\n(S'id'\ntR.\n"),
        "artifact_unsupported": ("notes.txt", "not a model artifact\n"),
        "artifact_empty": ("empty.pkl", ""),
        "mcp_manifest": (
            "mcp-manifest.json",
            json.dumps(
                {
                    "name": "qa-mcp",
                    "version": "1.0.0",
                    "tools": [
                        {
                            "name": "read_file",
                            "description": "Read a local file path.",
                            "inputSchema": {"type": "object"},
                        }
                    ],
                },
                indent=2,
            ),
        ),
        "a2a_card": (
            "a2a-card.json",
            json.dumps(
                {
                    "name": "qa-agent",
                    "version": "1.0.0",
                    "description": "Safe QA card",
                    "url": "http://localhost:8081/a2a",
                    "capabilities": {"streaming": False},
                },
                indent=2,
            ),
        ),
        "notebook": (
            "test.ipynb",
            json.dumps(
                {
                    "cells": [
                        {
                            "cell_type": "code",
                            "metadata": {},
                            "source": ['token = "sk-test-1234567890abcdefghijklmnopqrstuvwxyz"\n'],
                            "outputs": [],
                            "execution_count": 1,
                        }
                    ],
                    "metadata": {},
                    "nbformat": 4,
                    "nbformat_minor": 5,
                },
                indent=2,
            ),
        ),
    }

    created: dict[str, Path] = {}
    for key, (name, content) in files.items():
        path = fixtures / name
        path.write_text(content, encoding="utf-8")
        created[key] = path
    created["root"] = fixtures
    return created


def multipart_body(field: str, path: Path) -> tuple[bytes, str]:
    boundary = "sentinelqa" + "".join(random.choice(string.ascii_letters) for _ in range(16))
    data = path.read_bytes()
    parts = [
        f"--{boundary}\r\n".encode(),
        (
            f'Content-Disposition: form-data; name="{field}"; '
            f'filename="{path.name}"\r\n'
        ).encode(),
        b"Content-Type: application/octet-stream\r\n\r\n",
        data,
        b"\r\n",
        f"--{boundary}--\r\n".encode(),
    ]
    return b"".join(parts), f"multipart/form-data; boundary={boundary}"


def request(
    base_url: str,
    spec: RequestSpec,
    token: str,
    timeout: float,
) -> tuple[int, dict[str, str], str, float, str]:
    headers = dict(spec.headers)
    body_bytes: bytes | None = None
    if spec.auth:
        headers["Authorization"] = f"Bearer {token}"
    if spec.upload_file:
        body_bytes, content_type = multipart_body(spec.upload_field, spec.upload_file)
        headers["Content-Type"] = content_type
    elif spec.body is not None:
        if isinstance(spec.body, (bytes, bytearray)):
            body_bytes = bytes(spec.body)
        elif isinstance(spec.body, str):
            body_bytes = spec.body.encode("utf-8")
        else:
            body_bytes = json.dumps(spec.body).encode("utf-8")
            headers.setdefault("Content-Type", "application/json")

    url = join_url(base_url, spec.path)
    req = urllib.request.Request(url, data=body_bytes, method=spec.method, headers=headers)
    start = now_ms()
    try:
        with urllib.request.urlopen(req, timeout=timeout) as response:
            raw = response.read()
            elapsed = now_ms() - start
            return (
                response.status,
                {k.lower(): v for k, v in response.headers.items()},
                raw.decode("utf-8", errors="replace"),
                elapsed,
                "",
            )
    except urllib.error.HTTPError as exc:
        raw = exc.read()
        elapsed = now_ms() - start
        return (
            exc.code,
            {k.lower(): v for k, v in exc.headers.items()},
            raw.decode("utf-8", errors="replace"),
            elapsed,
            "",
        )
    except (urllib.error.URLError, TimeoutError, socket.timeout) as exc:
        elapsed = now_ms() - start
        return 0, {}, "", elapsed, str(exc)


def extract_finding_count(payload: Any) -> int | None:
    if not isinstance(payload, dict):
        return None
    if isinstance(payload.get("finding_count"), int):
        return payload["finding_count"]
    if isinstance(payload.get("count"), int):
        return payload["count"]
    if isinstance(payload.get("findings"), list):
        return len(payload["findings"])
    if isinstance(payload.get("issues"), list):
        return len(payload["issues"])
    return None


def extract_action(payload: Any) -> str:
    if isinstance(payload, dict):
        return str(payload.get("action", "")).upper()
    return ""


def evaluate(spec: RequestSpec, status: int, headers: dict[str, str], body: str, error: str, duration: float) -> Result:
    json_valid, payload = load_json(body)
    finding_count = extract_finding_count(payload) if json_valid else None
    action = extract_action(payload) if json_valid else ""
    flags: list[str] = []

    if error:
        flags.append(f"transport_error:{error}")
    if status not in spec.expected_status:
        flags.append(f"status:{status} not in {sorted(spec.expected_status)}")
    if spec.expect_json and not json_valid:
        flags.append("invalid_json")
    if spec.expect_csp and "content-security-policy" not in headers:
        flags.append("missing_csp")
    if spec.expect_no_server_header and "server" in headers:
        flags.append("server_header_present")
    if spec.min_findings is not None:
        if finding_count is None or finding_count < spec.min_findings:
            flags.append(f"finding_count<{spec.min_findings}")
    if spec.max_findings is not None:
        if finding_count is None or finding_count > spec.max_findings:
            flags.append(f"finding_count>{spec.max_findings}")
    if spec.expected_action and action not in spec.expected_action:
        flags.append(f"action:{action or '<none>'}")

    lowered = body.lower()
    for marker in ("traceback", "exception", "panic", "segmentation fault", "permission denied"):
        if marker in lowered:
            flags.append(marker.replace(" ", "_"))

    return Result(
        name=spec.name,
        category=spec.category,
        method=spec.method,
        path=spec.path,
        expected=",".join(str(x) for x in sorted(spec.expected_status)),
        status_code=status,
        duration_ms=round(duration, 1),
        passed=not flags and not spec.skip_reason,
        skipped=bool(spec.skip_reason),
        json_valid=json_valid,
        finding_count=finding_count,
        action=action,
        issue_flags=flags if not spec.skip_reason else [f"skipped:{spec.skip_reason}"],
        evidence=safe_preview(error or body, 240),
        body_prefix=safe_preview(body, 1000),
    )


def login(base_url: str, user: str, password: str, timeout: float) -> tuple[str, Result]:
    spec = RequestSpec(
        name="auth-login-valid",
        category="auth",
        method="POST",
        path="/api/auth/login",
        expected_status={200},
        body={"username": user, "password": password},
        expect_json=True,
        expect_csp=True,
        expect_no_server_header=True,
    )
    status, headers, body, duration, error = request(base_url, spec, "", timeout)
    result = evaluate(spec, status, headers, body, error, duration)
    ok, payload = load_json(body)
    token = str(payload.get("token", "")) if ok and isinstance(payload, dict) else ""
    if not token:
        result.passed = False
        result.issue_flags.append("missing_token")
    return token, result


def build_specs(fixtures: dict[str, Path], include_remote: bool) -> list[RequestSpec]:
    specs: list[RequestSpec] = [
        RequestSpec("root-spa", "public", "GET", "/", {200}, expect_json=False, expect_csp=True, expect_no_server_header=True),
        RequestSpec("root-health", "public", "GET", "/health", {200}, expect_csp=True, expect_no_server_header=True),
        RequestSpec("api-health", "public", "GET", "/api/health", {200}, expect_csp=True, expect_no_server_header=True),
        RequestSpec("api-docs", "public", "GET", "/api/docs", {200}, expect_json=False, expect_csp=True, expect_no_server_header=True),
        RequestSpec("openapi", "public", "GET", "/api/openapi.json", {200}, expect_csp=True, expect_no_server_header=True),
        RequestSpec(
            "cors-preflight",
            "security",
            "OPTIONS",
            "/api/firewall/scan",
            {200},
            headers={
                "Origin": "http://localhost:5173",
                "Access-Control-Request-Method": "POST",
                "Access-Control-Request-Headers": "content-type,authorization",
            },
            expect_json=False,
            expect_csp=True,
            expect_no_server_header=True,
        ),
        RequestSpec(
            "auth-login-invalid",
            "auth",
            "POST",
            "/api/auth/login",
            {401},
            body={"username": "admin", "password": "wrong-password"},
            expect_csp=True,
            expect_no_server_header=True,
        ),
    ]

    protected_paths = [
        ("protected-firewall", "POST", "/api/firewall/scan", {"prompt": "hello", "scan_type": "input"}),
        ("protected-artifact", "POST", "/api/artifacts/scan", None),
        ("protected-sast", "POST", "/api/sast/scan", {"path": str(fixtures["root"])}),
        ("protected-agent", "POST", "/api/agent/scan", {"path": str(fixtures["root"])}),
        ("protected-supply-chain", "POST", "/api/supply-chain/scan", {"path": str(fixtures["root"])}),
        ("protected-diff", "POST", "/api/diff/scan", {"target": "--staged"}),
        ("protected-notebook", "POST", "/api/notebook/scan", {"path": str(fixtures["notebook"])}),
        ("protected-redteam", "POST", "/api/redteam/scan", {"target": "echo"}),
        ("protected-secrets", "POST", "/api/secrets/scan", {"path": str(fixtures["root"])}),
        ("protected-dep-scan", "POST", "/api/dep-scan/scan", {"path": str(fixtures["root"]), "ecosystem": "pypi"}),
        ("protected-mcp", "POST", "/api/mcp/scan", {"target": str(fixtures["mcp_manifest"])}),
        ("protected-a2a", "POST", "/api/a2a/scan", {"path": str(fixtures["a2a_card"])}),
        ("protected-aibom", "POST", "/api/aibom/generate", {"path": str(fixtures["root"]), "format": "cyclonedx"}),
        ("protected-validate", "GET", "/api/validate", None),
        ("protected-benchmark", "GET", "/api/benchmark", None),
        ("protected-stats", "GET", "/api/stats", None),
        ("protected-scanners", "GET", "/api/scanners", None),
        ("protected-evaluate", "GET", "/api/evaluate", None),
        ("protected-plugins", "GET", "/api/plugins", None),
        ("protected-doctor", "GET", "/api/doctor", None),
        ("protected-policy", "GET", "/api/policy", None),
        ("protected-config", "GET", "/api/config", None),
        ("protected-history", "GET", "/api/history", None),
    ]
    for name, method, path, body in protected_paths:
        specs.append(
            RequestSpec(
                name=f"{name}-no-auth",
                category="auth-required",
                method=method,
                path=path,
                expected_status={401},
                body=body,
                expect_csp=True,
                expect_no_server_header=True,
            )
        )

    for item in MALICIOUS_FIREWALL_CORPUS:
        specs.append(
            RequestSpec(
                name=f"firewall-malicious-{item['name']}",
                category=f"firewall:{item['family']}",
                method="POST",
                path="/api/firewall/scan",
                expected_status={200},
                body={"prompt": item["text"], "scan_type": "input"},
                auth=True,
                expect_csp=True,
                expect_no_server_header=True,
                min_findings=1,
                expected_action={"BLOCK", "WARN"},
            )
        )
    for item in BENIGN_FIREWALL_CORPUS:
        specs.append(
            RequestSpec(
                name=f"firewall-benign-{item['name']}",
                category=f"firewall-benign:{item['family']}",
                method="POST",
                path="/api/firewall/scan",
                expected_status={200},
                body={"prompt": item["text"], "scan_type": "input"},
                auth=True,
                expect_csp=True,
                expect_no_server_header=True,
                max_findings=0,
                expected_action={"PASS", "ALLOW"},
            )
        )

    specs.extend(
        [
            RequestSpec(
                "firewall-invalid-empty-prompt",
                "schema",
                "POST",
                "/api/firewall/scan",
                {422},
                body={"prompt": "", "scan_type": "input"},
                auth=True,
                expect_csp=True,
                expect_no_server_header=True,
            ),
            RequestSpec(
                "sast-path-traversal",
                "security",
                "POST",
                "/api/sast/scan",
                {400, 422},
                body={"path": "../../etc/passwd"},
                auth=True,
                expect_csp=True,
                expect_no_server_header=True,
            ),
            RequestSpec(
                "artifact-malicious-pickle",
                "artifact",
                "POST",
                "/api/artifacts/scan",
                {200},
                auth=True,
                expect_csp=True,
                expect_no_server_header=True,
                upload_file=fixtures["artifact_pkl"],
            ),
            RequestSpec(
                "artifact-unsupported-extension",
                "artifact",
                "POST",
                "/api/artifacts/scan",
                {400},
                auth=True,
                expect_csp=True,
                expect_no_server_header=True,
                upload_file=fixtures["artifact_unsupported"],
            ),
            RequestSpec(
                "artifact-empty-file",
                "artifact",
                "POST",
                "/api/artifacts/scan",
                {400},
                auth=True,
                expect_csp=True,
                expect_no_server_header=True,
                upload_file=fixtures["artifact_empty"],
            ),
            RequestSpec(
                "sast-valid-fixture",
                "path-scan",
                "POST",
                "/api/sast/scan",
                {200},
                body={"path": str(fixtures["root"])},
                auth=True,
                expect_csp=True,
                expect_no_server_header=True,
            ),
            RequestSpec(
                "secrets-valid-fixture",
                "path-scan",
                "POST",
                "/api/secrets/scan",
                {200},
                body={"path": str(fixtures["root"]), "enable_entropy": True, "git_history": False},
                auth=True,
                expect_csp=True,
                expect_no_server_header=True,
                min_findings=1,
            ),
            RequestSpec(
                "supply-chain-valid-fixture",
                "path-scan",
                "POST",
                "/api/supply-chain/scan",
                {200},
                body={"path": str(fixtures["root"])},
                auth=True,
                expect_csp=True,
                expect_no_server_header=True,
            ),
            RequestSpec(
                "notebook-valid-fixture",
                "path-scan",
                "POST",
                "/api/notebook/scan",
                {200},
                body={"path": str(fixtures["notebook"])},
                auth=True,
                expect_csp=True,
                expect_no_server_header=True,
            ),
            RequestSpec(
                "mcp-manifest-fixture",
                "agent",
                "POST",
                "/api/mcp/scan",
                {200, 500},
                body={"target": str(fixtures["mcp_manifest"]), "manifest": str(fixtures["mcp_manifest"])},
                auth=True,
                expect_csp=True,
                expect_no_server_header=True,
            ),
            RequestSpec(
                "a2a-card-fixture",
                "agent",
                "POST",
                "/api/a2a/scan",
                {200},
                body={"path": str(fixtures["a2a_card"])},
                auth=True,
                expect_csp=True,
                expect_no_server_header=True,
            ),
            RequestSpec(
                "aibom-fixture",
                "inventory",
                "POST",
                "/api/aibom/generate",
                {200, 501},
                body={"path": str(fixtures["root"]), "format": "cyclonedx"},
                auth=True,
                expect_csp=True,
                expect_no_server_header=True,
            ),
            RequestSpec(
                "dep-scan-fixture",
                "supply-chain",
                "POST",
                "/api/dep-scan/scan",
                {200, 500, 501},
                body={"path": str(fixtures["root"]), "ecosystem": "pypi"},
                auth=True,
                expect_csp=True,
                expect_no_server_header=True,
            ),
        ]
    )

    if include_remote or os.environ.get("HF_TOKEN"):
        specs.append(
            RequestSpec(
                "hf-scan-remote",
                "remote",
                "POST",
                "/api/hf/scan",
                {200, 401, 403, 404, 500, 501},
                body={"repo": "bert-base-uncased", "deep": False},
                auth=True,
                expect_csp=True,
                expect_no_server_header=True,
            )
        )
    else:
        specs.append(
            RequestSpec(
                "hf-scan-remote",
                "remote",
                "POST",
                "/api/hf/scan",
                {0},
                auth=True,
                skip_reason="HF_TOKEN not set; remote scan skipped by harness",
            )
        )

    for method, path, name in [
        ("GET", "/api/stats", "stats"),
        ("GET", "/api/scanners", "scanners"),
        ("GET", "/api/evaluate", "evaluate"),
        ("GET", "/api/plugins", "plugins"),
        ("GET", "/api/doctor", "doctor"),
        ("GET", "/api/policy", "policy"),
        ("GET", "/api/config", "config"),
        ("GET", "/api/history", "history"),
        ("GET", "/api/validate", "validate"),
        ("GET", "/api/benchmark", "benchmark"),
    ]:
        specs.append(
            RequestSpec(
                f"info-{name}",
                "info",
                method,
                path,
                {200, 500},
                auth=True,
                expect_csp=True,
                expect_no_server_header=True,
            )
        )
    return specs


def run_api_matrix(base_url: str, user: str, password: str, timeout: float, out_dir: Path, include_remote: bool) -> list[Result]:
    fixtures = ensure_fixtures(out_dir)
    results: list[Result] = []
    token, login_result = login(base_url, user, password, timeout)
    results.append(login_result)

    specs = build_specs(fixtures, include_remote)
    for spec in specs:
        if spec.skip_reason:
            results.append(
                Result(
                    name=spec.name,
                    category=spec.category,
                    method=spec.method,
                    path=spec.path,
                    expected="skipped",
                    status_code=0,
                    duration_ms=0.0,
                    passed=False,
                    skipped=True,
                    issue_flags=[f"skipped:{spec.skip_reason}"],
                    evidence=spec.skip_reason,
                )
            )
            continue
        status, headers, body, duration, error = request(base_url, spec, token, timeout)
        results.append(evaluate(spec, status, headers, body, error, duration))
    return results


def inspect_refs(refs_dir: Path) -> list[dict[str, Any]]:
    repos: dict[str, dict[str, Any]] = {}
    if refs_dir.is_dir():
        for path in sorted(p for p in refs_dir.iterdir() if p.is_dir()):
            files = [p for p in path.rglob("*") if p.is_file() and ".git" not in p.parts]
            code_files = [
                p
                for p in files
                if p.suffix.lower() in {".py", ".ts", ".js", ".go", ".rs", ".yaml", ".yml", ".json", ".toml"}
            ]
            names = {p.name.lower() for p in files[:5000]}
            repos[path.name] = {
                "present": True,
                "path": str(path),
                "file_count": len(files),
                "code_config_count": len(code_files),
                "has_tests": any("test" in part.lower() for p in files for part in p.parts),
                "has_docs": any(name in names for name in {"readme.md", "docs", "usage.md", "architecture.md"}),
                "has_security": "security.md" in names,
            }

    rows: list[dict[str, Any]] = []
    for gap in REFERENCE_GAPS:
        info = repos.get(gap["repo"], {"present": False, "file_count": 0, "code_config_count": 0})
        row = dict(gap)
        row.update(
            {
                "present": bool(info.get("present")),
                "file_count": int(info.get("file_count", 0)),
                "code_config_count": int(info.get("code_config_count", 0)),
                "has_tests": bool(info.get("has_tests", False)),
                "has_docs": bool(info.get("has_docs", False)),
                "has_security": bool(info.get("has_security", False)),
            }
        )
        rows.append(row)

    known = {row["repo"] for row in rows}
    for name, info in sorted(repos.items()):
        if name not in known:
            rows.append(
                {
                    "repo": name,
                    "domain": "unmapped-reference",
                    "reference_feature": "not in curated parity map",
                    "sentinel_surface": "refs/parity",
                    "status": "unmapped",
                    "missing_tests": "needs triage",
                    "suggested_implementation": "Classify this .refs repo and add it to the parity manifest or ignore list.",
                    "priority": "P3",
                    "present": True,
                    "file_count": int(info.get("file_count", 0)),
                    "code_config_count": int(info.get("code_config_count", 0)),
                    "has_tests": bool(info.get("has_tests", False)),
                    "has_docs": bool(info.get("has_docs", False)),
                    "has_security": bool(info.get("has_security", False)),
                }
            )
    return rows


def markdown_table(headers: list[str], rows: list[list[Any]]) -> str:
    out = ["| " + " | ".join(headers) + " |", "| " + " | ".join(["---"] * len(headers)) + " |"]
    for row in rows:
        out.append("| " + " | ".join(str(cell).replace("\n", " ") for cell in row) + " |")
    return "\n".join(out)


def write_results_csv(path: Path, results: list[Result]) -> None:
    fields = list(asdict(results[0]).keys()) if results else []
    with path.open("w", encoding="utf-8", newline="") as fh:
        writer = csv.DictWriter(fh, fieldnames=fields)
        writer.writeheader()
        for result in results:
            row = asdict(result)
            row["issue_flags"] = ";".join(result.issue_flags)
            writer.writerow(row)


def coverage_markdown() -> str:
    rows = [[item["command"], item["api"], item["status"]] for item in CLI_API_COVERAGE]
    covered = sum(1 for item in CLI_API_COVERAGE if item["status"].startswith("covered"))
    partial = sum(1 for item in CLI_API_COVERAGE if item["status"].startswith("partial"))
    missing = len(CLI_API_COVERAGE) - covered - partial
    return "\n".join(
        [
            "# Sentinel CLI-to-API Coverage",
            "",
            f"- Commands/aliases mapped: {len(CLI_API_COVERAGE)}",
            f"- Covered: {covered}",
            f"- Partial: {partial}",
            f"- Missing/not applicable: {missing}",
            "",
            markdown_table(["Command", "API", "Status"], rows),
            "",
        ]
    )


def refs_gap_markdown(rows: list[dict[str, Any]]) -> str:
    table_rows = [
        [
            row["priority"],
            row["repo"],
            "yes" if row["present"] else "no",
            row["domain"],
            row["status"],
            row["reference_feature"],
            row["sentinel_surface"],
            row["missing_tests"],
            row["suggested_implementation"],
        ]
        for row in rows
    ]
    return "\n".join(
        [
            "# Sentinel .refs Gap Matrix",
            "",
            f"- Repositories inspected: {len(rows)}",
            f"- Present: {sum(1 for row in rows if row['present'])}",
            f"- Missing: {sum(1 for row in rows if not row['present'])}",
            "",
            markdown_table(
                [
                    "Priority",
                    "Repo",
                    "Present",
                    "Domain",
                    "Status",
                    "Reference Feature",
                    "Sentinel Surface",
                    "Missing Tests",
                    "Suggested Implementation",
                ],
                table_rows,
            ),
            "",
        ]
    )


def report_markdown(results: list[Result], refs_rows: list[dict[str, Any]], base_url: str) -> str:
    total = len(results)
    skipped = sum(1 for r in results if r.skipped)
    passed = sum(1 for r in results if r.passed)
    failed = total - passed - skipped
    invalid_json = sum(1 for r in results if not r.json_valid and not r.skipped and r.expected != "200")
    failures = [r for r in results if not r.passed and not r.skipped]
    firewall = [r for r in results if r.category.startswith("firewall")]
    fn = [
        r
        for r in firewall
        if r.category.startswith("firewall:") and any(flag.startswith("finding_count<") or flag.startswith("action:") for flag in r.issue_flags)
    ]
    fp = [
        r
        for r in firewall
        if r.category.startswith("firewall-benign") and any(flag.startswith("finding_count>") or flag.startswith("action:") for flag in r.issue_flags)
    ]

    lines = [
        "# Sentinel API QA Report",
        "",
        "## Environment",
        "",
        f"- Base URL: `{base_url}`",
        f"- Generated: `{time.strftime('%Y-%m-%d %H:%M:%S %Z')}`",
        f"- Bypass taxonomy families: {', '.join(BYPASS_TAXONOMY)}",
        "",
        "## Executive Summary",
        "",
        f"- Total scenarios: {total}",
        f"- Passed: {passed}",
        f"- Failed: {failed}",
        f"- Skipped: {skipped}",
        f"- Invalid JSON candidates: {invalid_json}",
        f"- Firewall FN candidates: {len(fn)}",
        f"- Firewall FP candidates: {len(fp)}",
        f"- .refs gaps listed: {len(refs_rows)}",
        "",
        "## Top Findings",
        "",
    ]
    if failures:
        rows = [
            [
                "HIGH" if "status:" in ";".join(r.issue_flags) else "MEDIUM",
                r.name,
                f"{r.method} {r.path}",
                r.status_code,
                "; ".join(r.issue_flags),
                r.evidence[:160],
            ]
            for r in failures[:30]
        ]
        lines.append(markdown_table(["Severity", "Scenario", "Request", "Status", "Problem", "Evidence"], rows))
    else:
        lines.append("No failing scenarios.")

    lines.extend(
        [
            "",
            "## Endpoint Coverage",
            "",
            markdown_table(
                ["Scenario", "Category", "Method", "Path", "Status", "ms", "Findings", "Action", "Result"],
                [
                    [
                        r.name,
                        r.category,
                        r.method,
                        r.path,
                        r.status_code,
                        r.duration_ms,
                        "" if r.finding_count is None else r.finding_count,
                        r.action,
                        "SKIP" if r.skipped else ("PASS" if r.passed else "FAIL"),
                    ]
                    for r in results
                ],
            ),
            "",
            "## Reproduction",
            "",
            "```bash",
            f"scripts/sentinel-api-qa --base-url {base_url} --out-dir {DEFAULT_OUT_DIR}",
            "```",
            "",
        ]
    )
    return "\n".join(lines)


def run_offline(out_dir: Path, refs_dir: Path) -> int:
    out_dir.mkdir(parents=True, exist_ok=True)
    fixtures = ensure_fixtures(out_dir)
    refs_rows = inspect_refs(refs_dir)
    write_json(out_dir / "fixtures.json", {k: str(v) for k, v in fixtures.items()})
    write_text(out_dir / "api-coverage.md", coverage_markdown())
    write_text(out_dir / "refs-gap.md", refs_gap_markdown(refs_rows))
    write_json(out_dir / "refs-gap.json", refs_rows)
    write_json(out_dir / "bypass-taxonomy.json", {"families": BYPASS_TAXONOMY})
    return 0


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description="HTTP-only Sentinel dashboard API QA harness.")
    parser.add_argument("--base-url", default=DEFAULT_BASE_URL)
    parser.add_argument("--username", default=os.environ.get("SENTINEL_USER", "admin"))
    parser.add_argument("--password", default=os.environ.get("SENTINEL_PASSWORD", "local-dev-password"))
    parser.add_argument("--out-dir", type=Path, default=DEFAULT_OUT_DIR)
    parser.add_argument("--refs-dir", type=Path, default=Path(".refs"))
    parser.add_argument("--timeout", type=float, default=DEFAULT_TIMEOUT)
    parser.add_argument("--include-remote", action="store_true", help="Run HF/network-dependent scenarios.")
    parser.add_argument("--offline", action="store_true", help="Only generate fixtures/coverage/.refs reports.")
    parser.add_argument("--fail-on-failures", action="store_true")
    args = parser.parse_args(argv)

    args.out_dir.mkdir(parents=True, exist_ok=True)
    if args.offline:
        return run_offline(args.out_dir, args.refs_dir)

    try:
        results = run_api_matrix(
            base_url=args.base_url,
            user=args.username,
            password=args.password,
            timeout=args.timeout,
            out_dir=args.out_dir,
            include_remote=args.include_remote,
        )
        refs_rows = inspect_refs(args.refs_dir)
        write_json(args.out_dir / "results.json", [asdict(r) for r in results])
        write_results_csv(args.out_dir / "results.csv", results)
        write_json(args.out_dir / "refs-gap.json", refs_rows)
        write_text(args.out_dir / "refs-gap.md", refs_gap_markdown(refs_rows))
        write_text(args.out_dir / "api-coverage.md", coverage_markdown())
        write_text(args.out_dir / "report.md", report_markdown(results, refs_rows, args.base_url))

        failed = [r for r in results if not r.passed and not r.skipped]
        skipped = [r for r in results if r.skipped]
        print("Sentinel API QA")
        print(f"Base URL: {args.base_url}")
        print(f"Scenarios: {len(results)}")
        print(f"Passed: {sum(1 for r in results if r.passed)}")
        print(f"Failed: {len(failed)}")
        print(f"Skipped: {len(skipped)}")
        print(f"Report: {args.out_dir / 'report.md'}")
        print(f"Refs gap: {args.out_dir / 'refs-gap.md'}")
        print(f"Coverage: {args.out_dir / 'api-coverage.md'}")
        if failed[:10]:
            print("Top failures:")
            for result in failed[:10]:
                print(f"- {result.name}: {result.status_code} {'; '.join(result.issue_flags)}")
        return 1 if failed and args.fail_on_failures else 0
    except KeyboardInterrupt:
        print("Interrupted", file=sys.stderr)
        return 130
    except Exception:
        traceback.print_exc()
        return 2


if __name__ == "__main__":
    raise SystemExit(main())
