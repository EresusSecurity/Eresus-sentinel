def normalized_help(text: str, canonical: str, alias: str) -> str:
    cleaned = re.sub(r"\s+", " ", text.strip())
    cleaned = cleaned.replace(f"sentinel {alias}", f"sentinel {canonical}")
    cleaned = cleaned.replace(f"{canonical} ({alias})", canonical)
    cleaned = cleaned.replace(f"{alias} ({canonical})", canonical)
    return cleaned


def write_csv(rows: list[CaseResult], path: Path) -> None:
    with path.open("w", newline="", encoding="utf-8") as fh:
        writer = csv.DictWriter(
            fh,
            fieldnames=[
                "case_id",
                "category",
                "command_name",
                "command",
                "rc",
                "duration_ms",
                "timed_out",
                "status",
                "expected",
                "json_valid",
                "sarif_valid",
                "output_file",
                "output_file_exists",
                "output_file_nonempty",
                "output_file_valid",
                "help_clear",
                "traceback",
                "error_words",
                "empty_output",
                "notes",
                "stdout_1000",
                "stderr_1000",
            ],
        )
        writer.writeheader()
        for row in rows:
            writer.writerow(
                {
                    "case_id": row.case_id,
                    "category": row.category,
                    "command_name": row.command_name,
                    "command": row.cmd_text,
                    "rc": row.rc,
                    "duration_ms": f"{row.duration_ms:.1f}",
                    "timed_out": row.timed_out,
                    "status": row.status,
                    "expected": row.expected,
                    "json_valid": row.json_valid,
                    "sarif_valid": row.sarif_valid,
                    "output_file": row.output_file,
                    "output_file_exists": row.output_file_exists,
                    "output_file_nonempty": row.output_file_nonempty,
                    "output_file_valid": row.output_file_valid,
                    "help_clear": row.help_clear,
                    "traceback": row.traceback,
                    "error_words": row.error_words,
                    "empty_output": row.empty_output,
                    "notes": "; ".join(row.notes),
                    "stdout_1000": row.stdout_1000,
                    "stderr_1000": row.stderr_1000,
                }
            )


def severity_for(row: CaseResult) -> str:
    text = f"{row.stdout}\n{row.stderr}".lower()
    if row.timed_out:
        return "CRITICAL"
    if row.traceback or "segmentation fault" in text or "panic" in text:
        return "CRITICAL"
    if row.status == "CRASH":
        return "CRITICAL"
    if row.category in {"format", "output-file"} and row.status == "FAIL":
        return "HIGH"
    if row.rc not in {0, 1, 2, 124}:
        return "HIGH"
    if row.category in {"help", "alias"} and row.status == "FAIL":
        return "MEDIUM"
    if row.category in {"invalid", "aggressive"} and row.status == "FAIL":
        return "MEDIUM"
    return "LOW"


def summarize_aliases(rows: list[CaseResult]) -> list[dict[str, Any]]:
    by_id = {row.case_id: row for row in rows}
    out = []
    for canonical, alias in ALIASES:
        c = by_id.get(f"alias-help-{canonical}")
        a = by_id.get(f"alias-help-{alias}")
        if not c or not a:
            continue
        same_rc = c.rc == a.rc
        same_help = normalized_help(c.stdout, canonical, alias) == normalized_help(a.stdout, canonical, alias)
        cb = by_id.get(f"alias-behavior-{canonical}")
        ab = by_id.get(f"alias-behavior-{alias}")
        same_behavior = bool(cb and ab and cb.rc == ab.rc and cb.status == ab.status)
        difference = ""
        if not same_rc:
            difference = f"help rc {c.rc} vs {a.rc}"
        elif not same_help:
            difference = "help output differs"
        elif not same_behavior:
            difference = "runtime behavior differs"
        out.append(
            {
                "canonical": canonical,
                "alias": alias,
                "same_help": same_rc and same_help,
                "same_behavior": same_behavior,
                "difference": difference,
            }
        )
    return out


def command_matrix(rows: list[CaseResult]) -> dict[str, dict[str, str]]:
    matrix: dict[str, dict[str, str]] = {}
    for command in COMMANDS:
        matrix[command] = {
            "--help": "NT",
            "-h": "NT",
            "empty": "NT",
            "json": "NT",
            "sarif": "NT",
            "output_file": "NT",
            "invalid": "NT",
            "status": "PASS",
        }
    for row in rows:
        cmd = row.command_name
        if cmd not in matrix:
            continue
        mark = "PASS" if row.status == "PASS" else row.status
        if row.case_id.endswith("--help"):
            matrix[cmd]["--help"] = mark
        elif row.case_id.endswith("-h"):
            matrix[cmd]["-h"] = mark
        elif row.category == "empty":
            matrix[cmd]["empty"] = mark
        elif row.category == "format" and "-f json " in f" {row.cmd_text} ":
            matrix[cmd]["json"] = mark
        elif row.category == "format" and "-f sarif " in f" {row.cmd_text} ":
            matrix[cmd]["sarif"] = mark
        elif row.category == "output-file":
            matrix[cmd]["output_file"] = "FAIL" if row.status != "PASS" else "PASS"
        elif row.category == "invalid":
            matrix[cmd]["invalid"] = "FAIL" if row.status != "PASS" else "PASS"
    for command, values in matrix.items():
        if any(v in {"FAIL", "CRASH", "HANG"} for k, v in values.items() if k != "status"):
            values["status"] = "FAIL"
    return matrix


def format_validation(rows: list[CaseResult]) -> dict[str, dict[str, str]]:
    table: dict[str, dict[str, str]] = {
        cmd: {fmt: "NT" for fmt in FORMATS}
        for cmd in COMMANDS
    }
    for row in rows:
        if row.category != "format":
            continue
        text = f" {row.cmd_text} "
        for fmt in FORMATS:
            if f" -f {fmt} " in text:
                table[row.command_name][fmt] = "PASS" if row.status == "PASS" else row.status
    return table


def write_markdown_report(
    rows: list[CaseResult],
    env: dict[str, str],
    alias_rows: list[dict[str, Any]],
    out_path: Path,
) -> None:
    failed = [row for row in rows if row.status != "PASS"]
    hangs = [row for row in rows if row.status == "HANG"]
    crashes = [row for row in rows if row.status == "CRASH"]
    invalid_outputs = [
        row for row in rows
        if row.status == "FAIL" and row.category in {"format", "output-file"}
    ]
    findings = sorted(failed, key=lambda row: {"CRITICAL": 0, "HIGH": 1, "MEDIUM": 2, "LOW": 3}[severity_for(row)])
    matrix = command_matrix(rows)
    formats = format_validation(rows)

    lines: list[str] = []
    lines.append("# Sentinel CLI QA Report")
    lines.append("")
    lines.append("## Environment")
    lines.append("")
    lines.append(f"- OS: {env.get('os', '')}")
    lines.append(f"- Python: {env.get('python', '')}")
    lines.append(f"- Sentinel version: {env.get('sentinel_version', '')}")
    lines.append(f"- Install source: {env.get('install_source', '')}")
    lines.append(f"- Shell: {env.get('shell', '')}")
    lines.append(f"- Sentinel path: {env.get('sentinel_path', '')}")
    lines.append(f"- pip show sentinel: {env.get('pip_show', '')}")
    lines.append("")
    lines.append("## Executive Summary")
    lines.append("")
    lines.append(f"- Total commands tested: {len(COMMANDS)}")
    lines.append(f"- Total scenarios: {len(rows)}")
    lines.append(f"- Passed: {len(rows) - len(failed)}")
    lines.append(f"- Failed: {len(failed)}")
    lines.append(f"- Hangs: {len(hangs)}")
    lines.append(f"- Crashes: {len(crashes)}")
    lines.append(f"- Invalid outputs: {len(invalid_outputs)}")
    lines.append("")

    lines.append("## Critical Findings")
    lines.append("")
    lines.append("| Severity | Command | Problem | Evidence | Suggested Fix |")
    lines.append("| --- | --- | --- | --- | --- |")
    if not findings:
        lines.append("| - | - | No failing findings in this run | - | - |")
    else:
        for row in findings[:40]:
            sev = severity_for(row)
            evidence = (row.stderr_1000 or row.stdout_1000).replace("\n", " ").replace("|", "\\|")[:280]
            problem = "; ".join(row.notes) or row.status
            fix = suggested_fix(row)
            lines.append(
                f"| {sev} | `{row.cmd_text}` | {problem} | {evidence} | {fix} |"
            )
    lines.append("")

    lines.append("## Command Coverage Matrix")
    lines.append("")
    lines.append("| Command | --help | -h | empty run | json | sarif | output file | invalid input | status |")
    lines.append("| --- | --- | --- | --- | --- | --- | --- | --- | --- |")
    for command in COMMANDS:
        m = matrix[command]
        lines.append(
            f"| `{command}` | {m['--help']} | {m['-h']} | {m['empty']} | {m['json']} | {m['sarif']} | {m['output_file']} | {m['invalid']} | {m['status']} |"
        )
    lines.append("")

    lines.append("## Alias Consistency")
    lines.append("")
    lines.append("| Canonical | Alias | Same help? | Same behavior? | Difference |")
    lines.append("| --- | --- | --- | --- | --- |")
    for row in alias_rows:
        lines.append(
            f"| `{row['canonical']}` | `{row['alias']}` | {row['same_help']} | {row['same_behavior']} | {row['difference'] or '-'} |"
        )
    lines.append("")

    lines.append("## Output Format Validation")
    lines.append("")
    lines.append("| Command | table | json | sarif | csv | markdown | html | junit |")
    lines.append("| --- | --- | --- | --- | --- | --- | --- | --- |")
    for command in COMMANDS:
        f = formats[command]
        lines.append(
            f"| `{command}` | {f['table']} | {f['json']} | {f['sarif']} | {f['csv']} | {f['markdown']} | {f['html']} | {f['junit']} |"
        )
    lines.append("")

    lines.append("## UX Bugs")
    lines.append("")
    help_rows = [row for row in rows if row.case_id == "env-sentinel-help"]
    if help_rows and help_rows[0].rc != 0:
        lines.append(
            "- `sentinel help` is unsupported and returns argparse `invalid choice`. "
            "This is a UX bug because users naturally try `tool help`."
        )
    else:
        lines.append("- `sentinel help` returned successfully in this run.")
    lines.append("")

    lines.append("## Suggested Fixes")
    lines.append("")
    unique_fixes: list[str] = []
    for row in findings:
        fix = suggested_fix(row)
        if fix not in unique_fixes:
            unique_fixes.append(fix)
    for fix in unique_fixes[:20]:
        lines.append(f"- {fix}")
    if not unique_fixes:
        lines.append("- No fixes suggested because no failures were detected.")
    lines.append("")

    lines.append("## Reproduction Commands")
    lines.append("")
    for row in findings[:60]:
        lines.append(f"```bash\n{row.cmd_text}\n```")
    if not findings:
        lines.append("No failing reproduction commands.")
    lines.append("")

    lines.append("## Raw Artifacts")
    lines.append("")
    lines.append(f"- CSV: `{out_path.with_suffix('.csv')}`")
    lines.append("- Full stdout/stderr first 1000 chars are embedded in the CSV.")
    out_path.write_text("\n".join(lines) + "\n", encoding="utf-8")


def suggested_fix(row: CaseResult) -> str:
    if row.case_id == "env-sentinel-help":
        return "Add a `help` subcommand that dispatches to root help or `help <command>`."
    if row.timed_out:
        return "Add bounded file/device guards, progress cancellation, or reject long-running default service commands in QA mode."
    if row.traceback:
        return "Catch the exception at the command boundary and return a structured CLI error with exit code 2."
    if row.category == "format" and row.status == "FAIL":
        return "When `-f json/sarif` is selected, write machine-readable output only, without Rich headers or warnings."
    if row.category == "output-file":
        return "Honor global `-o` consistently for supported commands and surface write failures with a non-zero exit."
    if row.category == "help":
        return "Ensure every command and alias supports both `--help` and `-h` with usage text and exit code 0."
    if row.category == "alias":
        return "Route aliases through the same parser/action path as canonical commands."
    if row.category == "invalid":
        return "Validate invalid global options before command execution and return concise argparse errors."
    return "Add a regression test for this CLI path and normalize exit code/error messaging."


def main() -> int:
    parser = argparse.ArgumentParser(description="Import-free Sentinel CLI QA harness")
    parser.add_argument("--sentinel", default="sentinel", help="Sentinel executable")
    parser.add_argument("--workdir", default="/tmp/sentinel-cli-qa", help="Fixture directory")
    parser.add_argument("--out-dir", default="/tmp/sentinel-cli-qa-report", help="Report directory")
    parser.add_argument("--timeout", type=float, default=20.0, help="Max seconds per command")
    parser.add_argument("--quick", action="store_true", help="Limit generic matrix for smoke testing")
    args = parser.parse_args()

    workdir = Path(args.workdir)
    out_dir = Path(args.out_dir)
    out_dir.mkdir(parents=True, exist_ok=True)
    fx = create_fixtures(workdir)
    rows: list[CaseResult] = []

    def add(result: CaseResult) -> None:
        rows.append(result)
        mark = result.status
        print(
            f"[{mark:<5}] {result.case_id:<42} rc={result.rc:<3} "
            f"{result.duration_ms:>7.1f}ms  {result.cmd_text}",
            flush=True,
        )

    sentinel = args.sentinel

    # Environment commands requested by the user.
    env_cases = [
        ("env-which-sentinel", ["which", sentinel], "no-crash"),
        ("env-version", [sentinel, "--version"], "no-crash"),
        ("env-help", [sentinel, "--help"], "help"),
        ("env-python-version", ["python", "--version"], "no-crash"),
        ("env-pip-show", ["zsh", "-lc", "pip show sentinel || true"], "no-crash"),
        ("env-sentinel-help", [sentinel, "help"], "invalid"),
    ]
    for case_id, command, expected in env_cases:
        add(run_command(command, case_id=case_id, category="environment", command_name="env", timeout=args.timeout, expected=expected))

    commands = COMMANDS if not args.quick else COMMANDS[:12]

    # Help tests.
    for command in commands:
        add(run_command([sentinel, command, "--help"], case_id=f"help-{command}---help", category="help", command_name=command, timeout=args.timeout, expected="help"))
        add(run_command([sentinel, command, "-h"], case_id=f"help-{command}--h", category="help", command_name=command, timeout=args.timeout, expected="help"))

    # Empty command tests.
    for command in commands:
        timeout = 5.0 if command in {"serve", "proxy", "watch", "shell", "repl"} else args.timeout
        add(run_command([sentinel, command], case_id=f"empty-{command}", category="empty", command_name=command, timeout=timeout, expected="no-crash"))

    # Global flags with no extra args, matching the requested shape.
    for command in commands:
        for flag_index, flags in enumerate(GLOBAL_FLAGS):
            timeout = 5.0 if command in {"serve", "proxy", "watch", "shell", "repl"} else args.timeout
            add(run_command([sentinel, *flags, command], case_id=f"global-{command}-{flag_index}", category="global-flag", command_name=command, timeout=timeout, expected="no-crash"))

    # Output formats with no extra args, matching the requested shape.
    for command in commands:
        for fmt in FORMATS:
            timeout = 5.0 if command in {"serve", "proxy", "watch", "shell", "repl"} else args.timeout
            expected = "json" if fmt == "json" and command in {"plugins", "scanners", "doctor", "config", "version"} else "no-crash"
            if fmt == "sarif" and command in {"plugins", "scanners", "doctor", "config", "version"}:
                expected = "sarif"
            add(run_command([sentinel, "-f", fmt, command], case_id=f"format-{command}-{fmt}", category="format", command_name=command, timeout=timeout, expected=expected))

    # Output file tests with realistic args so write behavior is actually exercised.
    output_formats = [
        ("json", ".json"),
        ("sarif", ".sarif"),
        ("markdown", ".md"),
        ("html", ".html"),
    ]
    for command in commands:
        base, stdin_text, base_timeout = base_args(command, fx)
        for fmt, suffix in output_formats:
            output_path = out_dir / f"{command.replace('-', '_')}-{fmt}{suffix}"
            if output_path.exists():
                output_path.unlink()
            timeout = min(args.timeout, base_timeout)
            add(
                run_command(
                    [sentinel, "-f", fmt, "-o", str(output_path), command, *base],
                    case_id=f"outfile-{command}-{fmt}",
                    category="output-file",
                    command_name=command,
                    timeout=timeout,
                    stdin_text=stdin_text,
                    expected="file",
                    output_file=output_path,
                )
            )

    # Invalid value tests with realistic args.
    for command in commands:
        base, stdin_text, base_timeout = base_args(command, fx)
        timeout = min(args.timeout, base_timeout)
        invalid_cases = [
            (["-f", "invalid"], "invalid-format"),
            (["--min-severity", "INVALID"], "invalid-severity"),
            (["-f", "json", "-o", "/root/forbidden.json"], "forbidden-output"),
            (["-f", "json", "-o", "/dev/full"], "dev-full-output"),
        ]
        for flags, label in invalid_cases:
            add(
                run_command(
                    [sentinel, *flags, command, *base],
                    case_id=f"invalid-{command}-{label}",
                    category="invalid",
                    command_name=command,
                    timeout=timeout,
                    stdin_text=stdin_text,
                    expected="invalid",
                )
            )

    # Alias consistency: compare help and realistic behavior.
    for canonical, alias in ALIASES:
        add(run_command([sentinel, canonical, "--help"], case_id=f"alias-help-{canonical}", category="alias", command_name=canonical, timeout=args.timeout, expected="help"))
        add(run_command([sentinel, alias, "--help"], case_id=f"alias-help-{alias}", category="alias", command_name=alias, timeout=args.timeout, expected="help"))
        for command in (canonical, alias):
            base, stdin_text, base_timeout = base_args(command, fx)
            add(
                run_command(
                    [sentinel, command, *base],
                    case_id=f"alias-behavior-{command}",
                    category="alias",
                    command_name=command,
                    timeout=min(args.timeout, base_timeout),
                    stdin_text=stdin_text,
                    expected="no-crash",
                )
            )

    # Realistic scenarios explicitly requested.
    realistic = [
        ("real-scan", [sentinel, "scan", str(fx["root"])], None, 20.0),
        ("real-artifact-pkl", [sentinel, "artifact", str(fx["model_pkl"])], None, 20.0),
        ("real-hf-artifact-local", [sentinel, "hf-artifact", str(fx["root"])], None, 20.0),
        ("real-sast", [sentinel, "sast", str(fx["root"])], None, 20.0),
        ("real-secrets", [sentinel, "secrets-scan", str(fx["root"])], None, 20.0),
        ("real-dep-scan", [sentinel, "dep-scan", str(fx["root"]), "--no-osv", "--no-pip-audit"], None, 20.0),
        ("real-notebook-invalid", [sentinel, "notebook", str(fx["test_ipynb"])], None, 20.0),
        ("real-notebook-valid", [sentinel, "notebook", str(fx["valid_nb"])], None, 20.0),
        ("real-validate-extra-arg", [sentinel, "validate", str(fx["root"])], None, 20.0),
        ("real-aibom", [sentinel, "aibom", str(fx["root"])], None, 20.0),
        ("real-benchmark-extra-arg", [sentinel, "benchmark", str(fx["root"])], None, 20.0),
        ("real-fuzz", [sentinel, "fuzz"], None, 20.0),
        ("real-doctor", [sentinel, "doctor"], None, 20.0),
        ("real-stats", [sentinel, "stats", str(fx["root"])], None, 20.0),
        ("real-scanners", [sentinel, "scanners"], None, 20.0),
    ]
    for case_id, command, stdin_text, timeout in realistic:
        add(run_command(command, case_id=case_id, category="realistic", command_name=command[1], timeout=timeout, stdin_text=stdin_text, expected="no-crash"))

    long_path = "A" * 5000
    aggressive = [
        ("aggr-scan-missing", [sentinel, "scan", "/does/not/exist"], None, 20.0),
        ("aggr-scan-empty", [sentinel, "scan", ""], None, 20.0),
        ("aggr-scan-dot", [sentinel, "scan", "."], None, 20.0),
        ("aggr-scan-root", [sentinel, "scan", "/"], None, 20.0),
        ("aggr-scan-unknown-flag", [sentinel, "scan", str(fx["root"]), "--unknown-flag"], None, 20.0),
        ("aggr-scan-long-path", [sentinel, "scan", long_path], None, 20.0),
        ("aggr-artifact-missing", [sentinel, "artifact", str(fx["root"] / "missing.pkl")], None, 20.0),
        ("aggr-artifact-dev-null", [sentinel, "artifact", "/dev/null"], None, 20.0),
        ("aggr-artifact-dev-zero", [sentinel, "artifact", "/dev/zero"], None, 20.0),
    ]
    for case_id, command, stdin_text, timeout in aggressive:
        add(run_command(command, case_id=case_id, category="aggressive", command_name=command[1], timeout=timeout, stdin_text=stdin_text, expected="no-crash"))

    # Build environment summary from actual command results and host metadata.
    by_id = {row.case_id: row for row in rows}
    env = {
        "os": f"{platform.system()} {platform.release()} {platform.machine()}",
        "python": (by_id.get("env-python-version").stdout or by_id.get("env-python-version").stderr if by_id.get("env-python-version") else "").strip() or "python command not found",
        "sentinel_version": (by_id.get("env-version").stdout if by_id.get("env-version") else "").strip(),
        "install_source": "real terminal binary",
        "shell": os.environ.get("SHELL", ""),
        "sentinel_path": (by_id.get("env-which-sentinel").stdout if by_id.get("env-which-sentinel") else "").strip(),
        "pip_show": (by_id.get("env-pip-show").stdout or by_id.get("env-pip-show").stderr if by_id.get("env-pip-show") else "").strip()[:300],
    }

    alias_rows = summarize_aliases(rows)
    csv_path = out_dir / "sentinel-cli-qa.csv"
    md_path = out_dir / "sentinel-cli-qa.md"
    write_csv(rows, csv_path)
    write_markdown_report(rows, env, alias_rows, md_path)

    failed = [row for row in rows if row.status != "PASS"]
    print()
    print(f"Report: {md_path}")
    print(f"CSV:    {csv_path}")
    print(f"Total:  {len(rows)}")
    print(f"Failed: {len(failed)}")
    print(f"Hangs:  {sum(1 for row in rows if row.status == 'HANG')}")
    print(f"Crash:  {sum(1 for row in rows if row.status == 'CRASH')}")
    return 1 if failed else 0


if __name__ == "__main__":
    raise SystemExit(main())
